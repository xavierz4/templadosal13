---
import PublicLayout from '@shared/ui/PublicLayout.astro';
import Navbar from '@shared/ui/Navbar.svelte';
import Footer from '@shared/ui/Footer.astro';
import { ColdContactForm } from '@modules/contact';
---

<PublicLayout title="Contacto Corporativo | Templados AL13" description="Canal directo de comunicación en frío para arquitectos, contratistas y requerimientos B2B sobre vidrio templado.">
  <Navbar client:load />

  <main class="min-h-screen bg-al13-background pt-32 pb-24 px-6 md:px-12">
    <div class="max-w-6xl mx-auto">
      
      <!-- Encabezado de la Sección -->
      <div class="mb-16 text-center md:text-left">
        <h1 class="text-4xl md:text-6xl font-heading font-bold text-white tracking-tight mb-4">
          Hablemos de <span class="text-gradient">Ingeniería.</span>
        </h1>
        <p class="text-zinc-400 text-lg md:text-xl max-w-2xl">
          Escríbenos para requerimientos especiales, facturación corporativa o si deseas licitar un gran proyecto estructural.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Listado de Sedes Corporativas y Canales Directos -->
        <div class="lg:col-span-5 space-y-10">
          
          <div class="glass-panel p-8 rounded-2xl border border-white/5 space-y-6">
            <h3 class="text-xl font-bold text-white border-b border-white/10 pb-4">
              Información de Contacto
            </h3>

            <div class="space-y-4">
              <!-- Sede -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-al13-cyan/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-al13-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.242-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-medium">Sede Operativa Principal</h4>
                  <p class="text-zinc-400 text-sm mt-1">Calle Ficticia 123 # 45-67<br/>Riohacha, La Guajira, Colombia</p>
                </div>
              </div>

              <!-- General Email -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-al13-emerald/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-al13-emerald" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-medium">Correo Electrónico</h4>
                  <p class="text-zinc-400 text-sm mt-1"><a href="mailto:hola@templadosal13.com" class="hover:text-al13-emerald transition-colors">hola@templadosal13.com</a><br/><a href="mailto:leads@templadosal13.com" class="hover:text-al13-emerald transition-colors">leads@templadosal13.com</a></p>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-al13-cyan/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-al13-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-medium">Atención Telefónica</h4>
                  <p class="text-zinc-400 text-sm mt-1">Lunes a Viernes<br/>8:00 AM — 6:00 PM (COT)</p>
                </div>
              </div>

            </div>
          </div>

          <!-- Componente Direct Tactic -->
          <div class="p-6 bg-zinc-900 overflow-hidden border border-white/5 rounded-2xl relative">
            <h4 class="text-white font-bold mb-2">¿Tienes dimensiones listas?</h4>
            <p class="text-zinc-400 text-sm mb-4 relative z-10">
              Nuestro motor de Viabilidad B2B evalúa tu perfil paramétrico de forma inmediata evitando errores en obra.
            </p>
            <a href="/catalogo" class="text-al13-cyan text-sm font-semibold hover:underline relative z-10 flex items-center gap-1">
              Ir al Cotizador Inteligente →
            </a>
          </div>

        </div>

        <!-- Formulario (Island SSR) -->
        <div class="lg:col-span-7">
          <ColdContactForm client:visible />
        </div>

      </div>
    </div>
  </main>

  <Footer />
</PublicLayout>
