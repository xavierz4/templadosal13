---
import Layout from '@shared/ui/Layout.astro';
import Badge from '@shared/ui/Badge.svelte';
---

<Layout>
	<main class="flex min-h-screen items-center justify-center relative overflow-hidden bg-al13-black">
		<!-- Elementos decorativos (Fondo Industrial) -->
		<div class="absolute w-[800px] h-[800px] rounded-full blur-[120px] bg-al13-gold/5 mix-blend-screen pointer-events-none z-0"></div>
		
		<!-- Contenedor Glassmorphism (Isla Central) -->
		<div class="glass-panel relative z-10 flex flex-col items-center justify-center p-12 rounded-3xl max-w-2xl text-center space-y-6">
			
			<Badge text="Boutique Industrial" type="premium" client:load />
			
			<h1 class="text-5xl md:text-6xl font-heading font-light tracking-tight text-white m-0">
				Templados <span class="text-gradient">AL13</span>
			</h1>
			
			<p class="text-zinc-400 font-sans text-sm md:text-base leading-relaxed max-w-lg mb-4">
				Redefiniendo el estándar arquitectónico en cristal templado y estructuras de aluminio. Preparados para la revolución B2B de 2026.
			</p>

			<div class="flex flex-col sm:flex-row gap-4 mt-8">
				<button class="bg-white text-al13-black px-8 py-3 rounded-lg text-sm font-semibold hover:scale-105 transition-transform duration-300 shadow-xl shadow-white/10">
					Cotizar Proyecto
				</button>
				<button class="glass-panel-light px-8 py-3 rounded-lg text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-300">
					Ver Catálogo
				</button>
			</div>
		</div>
	</main>
</Layout>
