---
import '@core/theme/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>404 - Página no encontrada | Templados AL13</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        background: #090a0c;
        color: #f5f5f5;
        font-family: 'Inter', sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .title {
        font-family: 'Outfit', sans-serif;
        font-size: 6rem;
        font-weight: 700;
        background: linear-gradient(to bottom right, #d4af37, #856a1b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
      }
      .subtitle {
        font-size: 1.5rem;
        color: #e0e0e0;
        margin-top: 0;
        margin-bottom: 2rem;
      }
      .ptext {
        color: rgba(255, 255, 255, 0.6);
        max-width: 400px;
        margin-bottom: 2.5rem;
      }
      .btn {
        padding: 0.75rem 1.5rem;
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        color: #090a0c;
        background: #d4af37;
        text-decoration: none;
        border-radius: 0.5rem;
        transition: transform 0.2s, background 0.2s;
      }
      .btn:hover {
        background: #e6c245;
        transform: scale(1.05);
      }
    </style>
  </head>
  <body>
    <h1 class="title">404</h1>
    <h2 class="subtitle">Destino Desconocido</h2>
    <p class="ptext">La ruta administrativa o pública a la que intentas acceder no existe en la arquitectura del sistema.</p>
    <a href="/" class="btn">Volver al Inicio</a>
  </body>
</html>
