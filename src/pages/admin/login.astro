---
import { LoginForm } from '@modules/admin';
import { createSupabaseServerClient } from '@core/infrastructure/supabaseServer';

// SSR obligatorio para auth con cookies
export const prerender = false;

// Task 4.1.3 — Redirect si ya está autenticado (no mostrar login a sesión activa)
const supabase = createSupabaseServerClient(Astro.cookies);
const {
  data: { session },
} = await supabase.auth.getSession();

if (session) {
  return Astro.redirect('/admin', 302);
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta
      name="description"
      content="Panel de Administración Templados AL13 — Acceso restringido"
    />
    <title>Login | Admin — Templados AL13</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts already loaded via global.css @fontsource imports -->
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, #090a0c 0%, #0f1115 50%, #1a1a2e 100%);
        color: #f5f5f5;
        overflow-x: hidden;
      }

      /* Subtle animated background pattern */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background:
          radial-gradient(ellipse at 20% 80%, rgba(212, 175, 55, 0.03) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, rgba(224, 224, 224, 0.02) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
      }
    </style>
  </head>
  <body>
    <main>
      <LoginForm client:load />
    </main>
  </body>
</html>
