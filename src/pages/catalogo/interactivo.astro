---
import PublicLayout from '@shared/ui/PublicLayout.astro';
import { Scene3DCanvas } from '@modules/render';
---

<PublicLayout
  title="Catálogo Interactivo 3D | Templados AL13"
  description="Explora nuestros productos arquitectónicos en 3D. Rota, acerca y visualiza los detalles de nuestro vidrio templado y aluminio anonizado AL13."
>
  <!-- Background Noise & Global Texture -->
  <div
    class="fixed inset-0 pointer-events-none opacity-20 z-0 bg-[url('/noise.webp')] mix-blend-overlay"
  >
  </div>

  <!-- Main Container: 100vh split into 60/40 on large screens -->
  <main
    class="relative h-screen w-full flex flex-col lg:flex-row overflow-hidden bg-[#0A0A0A pt-16 lg:pt-0"
  >
    <!-- Left Section: 3D Render Engine (60% Desktop, 50% Mobile) -->
    <section
      class="relative w-full h-[50vh] lg:h-full lg:w-[60%] flex items-center justify-center bg-black/40 z-10"
    >
      <div
        class="absolute inset-0 z-0 bg-gradient-to-r from-transparent to-[#0A0A0A]/80 pointer-events-none lg:block hidden"
      >
      </div>

      <!-- Threlte 3D Canvas -->
      <div class="absolute inset-0 w-full h-full cursor-grab active:cursor-grabbing">
        <Scene3DCanvas client:load fallbackImageSrc="/hero_placeholder.jpg" class="w-full h-full" />
      </div>

      <!-- UX Hint for dragging -->
      <div
        class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2 bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 text-white/60 pointer-events-none z-20 animate-pulse"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8"></path><path d="m8 12 4-4 4 4"
          ></path></svg
        >
        <span class="text-xs tracking-wider uppercase">Arrastra para girar</span>
      </div>
    </section>

    <!-- Right Section: Interactive Product Configurator (40% Desktop, 50% Mobile) -->
    <section
      class="relative w-full h-[50vh] lg:h-full lg:w-[40%] bg-[#0f0f12] flex flex-col justify-center px-8 lg:px-16 border-t lg:border-t-0 lg:border-l border-white/10 z-20 overflow-y-auto"
    >
      <!-- Badges & Taxonomy -->
      <div class="flex items-center gap-3 mb-6">
        <span
          class="px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-widest"
          >Premium</span
        >
        <span class="text-xs text-zinc-500 font-mono">ID: AL13-SYS-01</span>
      </div>

      <!-- Typography -->
      <h1
        class="text-4xl lg:text-5xl font-sans font-bold text-white mb-4 tracking-tight leading-tight"
      >
        División <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400"
          >Arquitectónica</span
        >
      </h1>

      <p class="text-zinc-400 text-sm lg:text-base leading-relaxed mb-10 max-w-sm">
        Sistema de perfilería expuesta en aluminio estructural. Cristal templado incoloro PBR con
        alto índice de refracción, ideal para espacios de lujo.
      </p>

      <!-- Specifications Grid -->
      <div class="grid grid-cols-2 gap-6 mb-12">
        <!-- Spec 1 -->
        <div class="flex flex-col gap-1 pb-4 border-b border-white/10">
          <span class="text-xs text-zinc-500 uppercase tracking-wider">Cristal</span>
          <span class="text-white font-medium">Templado 8mm / 10mm</span>
        </div>
        <!-- Spec 2 -->
        <div class="flex flex-col gap-1 pb-4 border-b border-white/10">
          <span class="text-xs text-zinc-500 uppercase tracking-wider">Perfilería</span>
          <span class="text-white font-medium">Aluminio Anodizado Mate</span>
        </div>
        <!-- Spec 3 -->
        <div class="flex flex-col gap-1 pb-4 border-b border-white/10">
          <span class="text-xs text-zinc-500 uppercase tracking-wider">Herrajes</span>
          <span class="text-white font-medium">Acero Inoxidable 304</span>
        </div>
        <!-- Spec 4 -->
        <div class="flex flex-col gap-1 pb-4 border-b border-white/10">
          <span class="text-xs text-zinc-500 uppercase tracking-wider">Acústica</span>
          <span class="text-white font-medium">Reducción Media (32dB)</span>
        </div>
      </div>

      <!-- Call to Action B2B -->
      <button
        class="w-full relative px-8 py-4 rounded-xl bg-white text-black font-bold text-sm tracking-widest uppercase transition-all duration-300 hover:bg-zinc-200 hover:scale-[1.02] shadow-[0_4px_20px_rgba(255,255,255,0.15)] flex justify-center items-center gap-2 group"
      >
        <span>Cotizar Este Sistema</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:translate-x-1"
          ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
      </button>

      <!-- Security / Guarantee seal -->
      <div class="mt-8 flex items-center justify-center gap-2 text-zinc-600">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path></svg
        >
        <span class="text-xs font-medium">Garantía Estructural AL13 de 5 años</span>
      </div>
    </section>
  </main>
</PublicLayout>
